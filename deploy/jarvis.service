[Unit]
Description=Jarvis MCP — Personal AI Assistant Server
After=network.target ollama.service

[Service]
Type=simple
User=%i
WorkingDirectory=/opt/jarvis-mcp
EnvironmentFile=/opt/jarvis-mcp/.env
ExecStart=/opt/jarvis-mcp/venv/bin/uvicorn src.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
