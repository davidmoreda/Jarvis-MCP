# ── Jarvis-MCP — Variables de entorno ──────────────────────────────────────
# Copia este fichero como .env y rellena los valores
# cp .env.example .env

# ── AUTH ──────────────────────────────────────────────────────────────────
# Cambia esto por una clave segura (openssl rand -hex 32)
JARVIS_API_KEY=change-me-to-a-strong-secret

# ── LLM ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# (Opcional) Claude API para tareas avanzadas. Si no tienes, deja vacío.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ── Google (Calendar + Gmail) ─────────────────────────────────────────────
# Descarga credentials.json de Google Cloud Console y ponlo aquí
GOOGLE_CREDENTIALS_PATH=credentials/google_credentials.json
GOOGLE_TOKEN_PATH=credentials/google_token.json

# ── Home Assistant ────────────────────────────────────────────────────────
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=your_long_lived_access_token_here

# ── Web Search ────────────────────────────────────────────────────────────
# Opcional: Brave Search API para mejores resultados (gratis hasta 2000/mes)
BRAVE_SEARCH_API_KEY=

# ── Local Files ───────────────────────────────────────────────────────────
# Directorios a los que Jarvis puede acceder (separados por coma)
LOCAL_FILES_ALLOWED_DIRS=/home/tu_usuario/Documents,/home/tu_usuario/Projects

# ── Persistencia ──────────────────────────────────────────────────────────
MEMORY_DB_PATH=data/memory.db
PROJECTS_DB_PATH=data/projects.db
